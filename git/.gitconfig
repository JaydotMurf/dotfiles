[user]
	email = 80340739+JaydotMurf@users.noreply.github.com
	name = Jerraill D. Murphy

[includeIf "gitdir:~/dev/work/"]
    path = ~/.gitconfig-work

[includeIf "gitdir:~/dev/personal/openclaw/"]
    path = ~/.gitconfig-openclaw

# Machine-local overrides (transport rewrites, host quirks). Untracked by
# design, like ~/.gitconfig-work; git silently skips it where absent.
[include]
    path = ~/.gitconfig-local

[init]
	defaultBranch = main
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
